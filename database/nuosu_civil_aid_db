create table biz_consultation
(
    id             bigint auto_increment
        primary key,
    user_id        bigint                               null comment '提问用户ID(匿名可为空)',
    question_cn    text                                 null comment '汉文问题',
    question_nuosu text                                 null comment '彝文问题',
    answer_cn      text                                 null comment '汉文答复',
    answer_nuosu   text                                 null comment '彝文答复',
    status         tinyint(1) default 0                 null comment '状态: 0未回答 1已回答',
    create_time    datetime   default CURRENT_TIMESTAMP not null,
    is_deleted     tinyint(1) default 0                 null
)
    comment '法律咨询记录表' collate = utf8mb4_unicode_ci
                             row_format = DYNAMIC;

create table sys_role
(
    id          bigint auto_increment
        primary key,
    role_name   varchar(20)                            not null,
    role_code   varchar(20)                            not null comment '角色代码',
    remark      varchar(255) default ''                null,
    update_time datetime     default CURRENT_TIMESTAMP null on update CURRENT_TIMESTAMP,
    is_deleted  tinyint(1)   default 0                 null,
    constraint uk_role_code
        unique (role_code)
)
    comment '系统角色表' collate = utf8mb4_unicode_ci
                         row_format = DYNAMIC;

create table sys_user
(
    id          bigint auto_increment
        primary key,
    username    varchar(50)                          not null,
    password    varchar(60)                          not null,
    mobile      varchar(11)                          null comment '用户手机号',
    role_id     bigint                               not null comment '角色ID',
    create_time datetime   default CURRENT_TIMESTAMP not null,
    update_time datetime   default CURRENT_TIMESTAMP null on update CURRENT_TIMESTAMP,
    is_deleted  tinyint(1) default 0                 null comment '逻辑删除',
    constraint uk_username
        unique (username)
)
    comment '系统用户表' collate = utf8mb4_unicode_ci
                         row_format = DYNAMIC;


